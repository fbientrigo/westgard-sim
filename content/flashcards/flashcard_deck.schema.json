{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://westgard-sim.local/schemas/flashcard_deck.schema.json",
  "title": "Flashcard Deck",
  "type": "object",
  "additionalProperties": false,
  "required": ["format_version", "deck_id", "metadata", "cards"],
  "properties": {
    "format_version": { "type": "string", "const": "1.0" },
    "deck_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "minLength": 3
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "subtitle", "language", "audience", "description", "author", "tags"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "subtitle": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 2 },
        "audience": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "author": { "type": "string", "minLength": 1 },
        "tags": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "source_url": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "card_type", "front", "back"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
            "minLength": 3
          },
          "card_type": {
            "type": "string",
            "enum": ["concept", "rule_identification", "interpretation", "lab_context"]
          },
          "front": { "type": "string", "minLength": 1 },
          "back": { "type": "string", "minLength": 1 },
          "tags": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "default": []
          },
          "sort_order": { "type": "integer", "minimum": 1 },
          "notes": { "type": "string" }
        }
      }
    }
  }
}

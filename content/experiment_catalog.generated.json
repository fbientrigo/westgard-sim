{
  "experiments": [
    {
      "id": "glucose_intro_course",
      "title": "Glucose Intro Course",
      "description": "Set inicial para practicar identificacion de errores de control de calidad.",
      "config": {
        "mean": 100.0,
        "sd": 2.0,
        "n_runs": 30,
        "seed": 42,
        "analyte": "Glucose"
      },
      "scenarios": [
        {
          "id": "syst_bias_early",
          "scenario_key": "bias",
          "scenario_name": "Systematic error",
          "parameters": {
            "start_run": 10,
            "shift_sd": 3.0
          }
        },
        {
          "id": "trend_progressive",
          "scenario_key": "drift",
          "scenario_name": "Trend",
          "parameters": {
            "start_run": 8,
            "total_drift_sd": 5.5,
            "drift_per_run": 0.25
          }
        },
        {
          "id": "rand_precision_loss",
          "scenario_key": "imprecision",
          "scenario_name": "Random error",
          "parameters": {
            "start_run": 12,
            "sd_multiplier": 2.8
          }
        }
      ]
    }
  ]
}